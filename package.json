{
  "name": "usb-auto-action",
  "version": "0.4.28",
  "description": "Auto-detects USB/SD insertion on Windows and shows an expandable action menu (compress intake copy, rename, delete from source).",
  "main": "main.js",
  "author": "Jake",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "node scripts/bundle.mjs",
    "prestart": "node scripts/bundle.mjs",
    "predev": "node scripts/bundle.mjs",
    "precheck": "node scripts/bundle.mjs",
    "predist": "node scripts/bundle.mjs",
    "prebuild:win": "node scripts/bundle.mjs",
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node --check main.js && node --check preload.js && node --check src/renderer.js && node --check watch-drives.js && node scripts/check-primitives.mjs && node --test test/",
    "test": "node --test test/",
    "pretest": "node scripts/bundle.mjs",
    "test:e2e": "node scripts/bundle.mjs && RUN_E2E=1 node --test --test-concurrency=1 test/e2e/*.e2e.mjs",
    "test:all": "npm test && npm run test:e2e",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "build:win": "electron-builder --win --publish never",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.15",
    "electron-updater": "^6.3.9",
    "exiftool-vendored": "^36.0.0",
    "gopro-telemetry": "^1.2.11",
    "multicast-dns": "^7.2.5",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.48.2"
  },
  "build": {
    "appId": "com.jakeg.usbautoaction",
    "productName": "USB SD Auto-Action",
    "asar": true,
    "artifactName": "USB-SD-Auto-Action-Setup-${version}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "CHANGELOG.md",
      "src/**/*",
      "!src/mod/**"
    ],
    "asarUnpack": [
      "node_modules/exiftool-vendored/**",
      "node_modules/exiftool-vendored.exe/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Virus7976",
        "repo": "usb-video-manager",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "USB SD Auto-Action"
    }
  },
  "keywords": []
}
