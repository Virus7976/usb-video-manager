{
  "name": "usb-auto-action",
  "version": "0.1.0",
  "description": "Auto-detects USB/SD insertion on Windows and shows an expandable action menu (compress intake copy, rename, delete from source).",
  "main": "main.js",
  "author": "Jake",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.15",
    "exiftool-vendored": "^36.0.0",
    "gopro-telemetry": "^1.2.11"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jakeg.usbautoaction",
    "productName": "USB SD Auto-Action",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "src/**/*"
    ],
    "asarUnpack": [
      "node_modules/exiftool-vendored/**",
      "node_modules/exiftool-vendored.exe/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "USB SD Auto-Action"
    }
  }
}
